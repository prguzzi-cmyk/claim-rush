# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
/dist
/tmp
/out-tsc

# dependencies
/node_modules
/.angular

# NOTE: src/environments/environment.ts used to be gitignored (Angular's
# historical "keep-secrets-out-of-vcs" default). We now keep it tracked —
# production builds swap it for environment.prod.ts via angular.json
# fileReplacements, and the dev file itself contains only placeholders.
# Removing this entry fixes TS2307 on Vercel/Linux where the file must exist
# on disk for module resolution to start.

# profiling files
chrome-profiler-events.json
speed-measure-plugin.json

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db
